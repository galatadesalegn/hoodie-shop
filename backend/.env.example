# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Database
MONGODB_URI=mongodb://localhost:27017/hoodie-store

# JWT (min 32 characters each)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# EmailJS — https://www.emailjs.com/
# Enable "Allow EmailJS API for non-browser applications" in Account > Security
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
EMAILJS_TEMPLATE_OTP=template_xxxxxxx
# Optional — falls back to EMAILJS_TEMPLATE_OTP if not set
EMAILJS_TEMPLATE_RESET=template_xxxxxxx
EMAILJS_TEMPLATE_ORDER=template_xxxxxxx
EMAILJS_TEMPLATE_EMAIL_CHANGE=template_xxxxxxx
# Or use one template for everything:
# EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Telegram (optional)
TELEGRAM_USERNAME=your_telegram_username

# Super Admin Seed
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=superadmin@hoodvault.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123
